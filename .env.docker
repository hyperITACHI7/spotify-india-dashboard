# ============================================================
# DOCKER ENVIRONMENT VARIABLES — .env.docker
# Used by docker-compose.yml for containerized deployment.
# Copy this to config/credentials/.env when running via Docker.
# ============================================================

# Google Translate (optional — leave blank to skip translation)
GOOGLE_TRANSLATE_API_KEY=

# Database — these match the Postgres container service name in docker-compose.yml
DB_HOST=db
DB_PORT=5432
DB_NAME=spotify_reviews
DB_USER=postgres
DB_PASSWORD=postgres

# Security
SECRET_KEY=change-me-in-production

# LLM Provider — swap all 3 to use any OpenAI-compatible provider (Groq, OpenAI, Together AI, etc.)
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
